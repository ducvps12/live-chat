# ───────── Server (Express Backend) ─────────
SERVER_PORT=4020
NODE_ENV=production

# ───────── Database ─────────
# "nemark_mongo" = tên container MongoDB trong docker-compose
MONGO_URI=mongodb://nemark_mongo:27017/nemark_prod

# ───────── JWT ─────────
# QUAN TRỌNG: Thay bằng key mạnh, random
JWT_SECRET=CHANGE_ME_TO_STRONG_RANDOM_KEY
JWT_EXPIRES_IN=7d

# ───────── Frontend (Next.js) ─────────
# Thay bằng IP hoặc domain thực tế của server
NEXT_PUBLIC_API_URL=http://160.187.229.177:4020/api

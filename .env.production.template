# ───────── NemarkChat Production Configuration ─────────
# Single-port deployment: Next.js + API + Socket.IO all on one port

# ───────── Server ─────────
PORT=4001
NODE_ENV=production

# ───────── Database ─────────
MONGO_URI=mongodb://127.0.0.1:27017/nemark_prod

# ───────── JWT ─────────
JWT_SECRET=CHANGE_ME_TO_STRONG_RANDOM_KEY
JWT_EXPIRES_IN=7d

# ───────── Frontend → Backend URL ─────────
# Same port! Just set to your domain or server IP with the same port:
# Example: http://nemarkdigital.com/api  (if behind reverse proxy on 80/443)
# Example: http://163.61.110.181:4001/api (direct IP access)
NEXT_PUBLIC_API_URL=http://163.61.110.181:4001/api

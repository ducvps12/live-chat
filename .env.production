# ───────── Server (Express Backend) ─────────
SERVER_PORT=4020
NODE_ENV=production

# ───────── Database ─────────
# "nemark_mongo" = container name in docker-compose
MONGO_URI=mongodb://nemark_mongo:27017/nemark_production

# ───────── JWT ─────────
JWT_SECRET=nemark-production-secret-change-me
JWT_EXPIRES_IN=7d

# ───────── Frontend (Next.js) ─────────
NEXT_PUBLIC_API_URL=http://160.187.229.177:4020/api

# ───────── Browser Pool (Puppeteer) ─────────
BROWSER_HEADLESS=true
BROWSER_POOL_MAX=3
